{
  "model": "SiameseEfficientNetLateFusion",
  "pretrained": true,
  "backbone": "efficientnet_b0",
  "model_arch": "late_fusion",
  "fusion": "feature_map_late_fusion_child_pattern_absdiff_multiply",
  "training": "head_only",
  "use_semantic_augmentation": true,
  "augmentation": {
    "scope": "train_only",
    "paired_child_pattern_affine": true,
    "paired_child_pattern_blur": true,
    "label_changing_single_branch_transforms": false
  },
  "image_resize": {
    "method": "resize_long_side_then_black_pad",
    "image_size": 224,
    "preserve_aspect_ratio": true
  },
  "num_epochs": 20,
  "early_stopping_patience": 4,
  "batch_size": 8,
  "learning_rate": 0.0003,
  "weight_decay": 0.0001,
  "seed": 42,
  "threshold_grid": [
    0.05,
    0.1,
    0.15,
    0.2,
    0.25,
    0.3,
    0.35,
    0.4,
    0.45,
    0.5,
    0.55,
    0.6,
    0.65,
    0.7,
    0.75,
    0.8,
    0.85,
    0.9,
    0.95
  ],
  "patients": [
