{
  "model": "SiameseEfficientNetGeometryFusion",
  "pretrained": false,
  "backbone": "efficientnet_b0",
  "model_arch": "vector_geometry_fusion",
  "fusion": "vector_absdiff_multiply_plus_geometry_mlp",
  "geometry_features": {
    "enabled": true,
    "feature_dim": 19,
    "source": "deterministic_child_pattern_mask_descriptors",
    "augmentation_applied_to_geometry": false
  },
  "training": "head_only",
  "use_semantic_augmentation": true,
  "augmentation": {
    "scope": "train_only",
    "paired_child_pattern_affine": true,
    "paired_child_pattern_blur": true,
    "label_changing_single_branch_transforms": false
  },
  "image_resize": {
    "method": "resize_long_side_then_black_pad",
    "image_size": 224,
    "preserve_aspect_ratio": true
  },
  "num_epochs": 1,
  "early_stopping_patience": 4,
  "batch_size": 8,
  "learning_rate": 0.0003,
  "weight_decay": 0.0001,
  "seed": 42,
  "threshold_grid": [
    0.05,
    0.1,
    0.15,
    0.2,
    0.25,
    0.3,
    0.35,
    0.4,
    0.45,
    0.5,
    0.55,
    0.6,
    0.65,
    0.7,
    0.75,
    0.8,
    0.85,
    0.9,
    0.95
  ],
  "patients": [
    "Aniela_Sonczewa",
    "Antonina_Lonc",
    "Franciszek_Lonc"
  ],
  "labels": [
    "omissions",
    "distortions",
    "perseverations",
    "rotations",
    "displacements",
    "relative_size_errors"
  ],
  "device": "cpu"
}